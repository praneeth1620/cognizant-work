/*
32. Insert and Update Operations in JDBC
Objective: Insert and update student records.
*/

class StudentDAO {

    public static void main(String[] args) {

        try {

            Connection con =
                    DriverManager.getConnection(
                            "jdbc:mysql://localhost:3306/studentdb",
                            "root",
                            "password"
                    );

            PreparedStatement insert =
                    con.prepareStatement(
                            "INSERT INTO students VALUES (?,?)"
                    );

            insert.setInt(1,101);
            insert.setString(2,"Praneeth");

            insert.executeUpdate();

            PreparedStatement update =
                    con.prepareStatement(
                            "UPDATE students SET name=? WHERE id=?"
                    );

            update.setString(1,"Kiran");
            update.setInt(2,101);

            update.executeUpdate();

            System.out.println(
                    "Insert & Update Successful"
            );

            con.close();

        }
        catch(Exception e) {
            System.out.println(e);
        }
    }
}

/*
33. Transaction Handling in JDBC
Objective: Simulate money transfer.
*/

class TransactionDemo {

    public static void main(String[] args) {

        try {

            Connection con =
                    DriverManager.getConnection(
                            "jdbc:mysql://localhost:3306/bank",
                            "root",
                            "password"
                    );

            con.setAutoCommit(false);

            Statement st =
                    con.createStatement();

            st.executeUpdate(
                    "UPDATE accounts SET balance=balance-500 WHERE id=1"
            );

            st.executeUpdate(
                    "UPDATE accounts SET balance=balance+500 WHERE id=2"
            );

            con.commit();

            System.out.println(
                    "Transaction Successful"
            );

            con.close();

        }
        catch(Exception e) {

            System.out.println(
                    "Transaction Failed"
            );
        }
    }
}

